{
  "name": "@wcagify/monorepo",
  "version": "0.4.11",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @wcagify/playground dev",
    "report:add": "pnpm --filter @wcagify/playground exec wcagify-new-report",
    "build": "pnpm --filter @focusring/wcagify build && pnpm --filter @wcagify/playground build",
    "preview": "pnpm --filter @wcagify/playground preview",
    "start": "node playground/.output/server/index.mjs",
    "lint": "oxlint -c oxlint.config.ts",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "knip": "knip",
    "typecheck": "pnpm -r run typecheck",
    "docs:dev": "pnpm --filter @wcagify/docs dev",
    "test": "pnpm -r --filter @focusring/wcagify --filter create-wcagify --filter @wcagify/browser-extension run test",
    "test:e2e": "vitest run --config test/e2e/vitest.config.ts",
    "test:coverage": "pnpm -r --filter @focusring/wcagify --filter create-wcagify run test:coverage",
    "ext:dev": "pnpm --filter @wcagify/browser-extension dev",
    "ext:build": "pnpm --filter @wcagify/browser-extension build",
    "docs:build": "pnpm --filter @wcagify/docs build",
    "release": "bumpp package.json packages/*/package.json docs/package.json --all -x \"npx changelogen --no-output\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "bumpp": "catalog:dev",
    "changelogen": "catalog:dev",
    "changelogithub": "catalog:dev",
    "husky": "catalog:dev",
    "knip": "catalog:dev",
    "lint-staged": "catalog:dev",
    "oxfmt": "catalog:dev",
    "oxlint": "catalog:dev",
    "playwright": "catalog:dev",
    "vitest": "catalog:dev"
  },
  "lint-staged": {
    "*.{ts,vue,js,mjs}": [
      "oxlint",
      "oxfmt"
    ],
    "*.{json,yaml,yml,md,css}": [
      "oxfmt"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ]
  }
}
