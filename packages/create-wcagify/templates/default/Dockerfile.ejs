FROM node:22-slim

RUN apt-get update && apt-get install -y --no-install-recommends python3 make g++ ca-certificates && apt-get clean && rm -rf /var/lib/apt/lists/*
RUN corepack enable

WORKDIR /app

COPY package.json pnpm-lock.yaml* ./
RUN pnpm install --frozen-lockfile

COPY . .
RUN pnpm build

RUN addgroup --system appuser && adduser --system --ingroup appuser appuser && chown -R appuser:appuser /app

USER appuser

EXPOSE 3000
ENV PORT=3000
ENV HOST=0.0.0.0

CMD ["node", ".output/server/index.mjs"]
