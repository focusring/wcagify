{
  "name": "create-wcagify",
  "version": "0.1.0",
  "description": "Scaffold a new WCAGify accessibility audit project",
  "keywords": [
    "a11y",
    "accessibility",
    "cli",
    "scaffold",
    "wcag"
  ],
  "license": "MIT",
  "author": "Focusring",
  "repository": {
    "type": "git",
    "url": "https://github.com/focusring/WCAGify.git",
    "directory": "packages/create-wcagify"
  },
  "bin": {
    "create-wcagify": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^13.1.0",
    "ejs": "^3.1.10",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/node": "^22.0.0",
    "tsdown": "^0.12.5",
    "typescript": "^5.9.3"
  }
}
