{
  "name": "create-wcagify",
  "version": "0.3.2",
  "description": "Scaffold a new WCAGify accessibility audit project",
  "keywords": [
    "a11y",
    "accessibility",
    "cli",
    "scaffold",
    "wcag"
  ],
  "license": "MIT",
  "author": "Focusring",
  "repository": {
    "type": "git",
    "url": "https://github.com/focusring/WCAGify.git",
    "directory": "packages/create-wcagify"
  },
  "bin": {
    "create-wcagify": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "catalog:cli",
    "commander": "catalog:cli",
    "ejs": "catalog:cli",
    "picocolors": "catalog:cli"
  },
  "devDependencies": {
    "@types/ejs": "catalog:dev",
    "@types/node": "catalog:dev",
    "@vitest/coverage-v8": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  }
}
