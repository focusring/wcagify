{
  "name": "@focusring/wcagify",
  "version": "0.4.11",
  "description": "WCAG accessibility audit tool — Nuxt layer with report generation and PDF export",
  "keywords": [
    "a11y",
    "accessibility",
    "audit",
    "nuxt",
    "wcag"
  ],
  "license": "MIT",
  "author": "Focusring",
  "repository": {
    "type": "git",
    "url": "https://github.com/focusring/WCAGify.git",
    "directory": "packages/wcagify"
  },
  "bin": {
    "wcagify-new-report": "./dist/cli/new-report.js"
  },
  "files": [
    "dist",
    "app",
    "server",
    "public",
    "locales",
    "shims",
    "nuxt.config.ts",
    "print.css"
  ],
  "type": "module",
  "main": "./nuxt.config.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./nuxt": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.js",
      "default": "./src/module.ts"
    },
    "./content": {
      "types": "./dist/content.d.ts",
      "import": "./dist/content.js",
      "default": "./src/content.ts"
    },
    "./pdf": {
      "types": "./dist/pdf/index.d.ts",
      "import": "./dist/pdf/index.js",
      "default": "./src/pdf/index.ts"
    },
    "./earl": {
      "types": "./dist/earl/index.d.ts",
      "import": "./dist/earl/index.js",
      "default": "./src/earl/index.ts"
    },
    "./locales/en": "./locales/en.ts",
    "./locales/nl": "./locales/nl.ts",
    "./print.css": "./print.css",
    "./layer": "./nuxt.config.ts"
  },
  "scripts": {
    "build": "tsdown",
    "prepare": "tsdown",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@iconify-json/lucide": "catalog:core",
    "@iconify-json/simple-icons": "catalog:core",
    "@libsql/client": "catalog:core",
    "@nuxt/a11y": "catalog:core",
    "@nuxt/content": "catalog:core",
    "@nuxt/fonts": "catalog:",
    "@nuxt/icon": "catalog:core",
    "@nuxt/kit": "catalog:core",
    "@nuxt/ui": "catalog:core",
    "@nuxtjs/i18n": "catalog:core",
    "@vueuse/core": "catalog:core",
    "nanoid": "catalog:",
    "nuxt-studio": "catalog:core",
    "sharp": "catalog:",
    "tailwindcss": "catalog:core",
    "zod": "catalog:core"
  },
  "devDependencies": {
    "@nuxt/schema": "catalog:dev",
    "@types/node": "catalog:dev",
    "@vitest/coverage-v8": "catalog:dev",
    "tsdown": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  }
}
